# Environment & Credentials
.env
.env.*
.venv
env/
venv/
ENV/
*.pem
*.key

# Python specific
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# AI & Backend specific
src_backend/uploads/*
!src_backend/uploads/.gitkeep
chroma_db/
pinecone_cache/
sample_docs/
data/
*.pdf
*.csv
*.xlsx
*.xls
*.docx
*.txt
*.jsonl
*.json
!requirements.txt
!package.json
!tsconfig.json
!tsconfig.app.json
!tsconfig.node.json

# Node/Frontend specific
node_modules/
dist/
dist-ssr/
*.local
.eslintcache
.stylelintcache
.vite/
.vercel/
.output/
.nuxt/

# IDEs & Tools
.vscode/
.idea/
.project
.pydevproject
.settings/
*.swp
*.swo

# Logs & Debugging
*.log
logs/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.tox/

# OS specific
.DS_Store
Thumbs.db
desktop.ini
